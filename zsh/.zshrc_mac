ZSH_DISABLE_COMPFIX=true

set -o vi
alias ssh="TERM=xterm ssh"
alias c="pbcopy"

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export PATH="$HOME/Programs/context-mapper-cli-6.12.0/bin:$PATH"
export PATH="$HOME/Programs:$PATH"
export LD_LIBRARY_PATH="$HOME/Downloads/instantclient_23_26/"
export PATH=/opt/homebrew/Caskroom/sqlcl/26.1.2.132.1334/sqlcl/bin:"$PATH"
export DOCKER_HOST="unix://${HOME}/.colima/default/docker.sock"
export TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE="/var/run/docker.sock"
export PATH="/opt/homebrew/bin:$PATH"
export PATH="$HOME/bin-jd:$PATH"

alias setup-rest="source ~/.envrc"
alias dev-token='setup-rest && export AUTH_TOKEN=$(client-credentials-token "$REV_KC_DEV_CLIENT_ID" "$KC_REV_CLIENT_SECRET" "$KEYCLOAK_DEV_TOKEN_URL") && echo $AUTH_TOKEN'
