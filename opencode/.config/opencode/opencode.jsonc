{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    // "oh-my-opencode@latest"
  ],
  "instructions": [
    // PDCA Workflow
    // see: https://www.infoq.com/articles/PDCA-AI-code-generation/
    ".opencode/workflow.md",
    // Pre-commit validations in PDCA Workflow.
    ".opencode/validation.md"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "jira": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-atlassian"
      ],
      "enabled": false,
      "environment": {
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_USERNAME": "{env:JIRA_USERNAME}",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}"
      }
    }
  },
  "lsp": {
    "kotlin-lsp": {
      "command": [
        "kotlin-lsp"
      ],
      "extensions": [
        ".kt",
        ".kts"
      ]
    }
  }
}
