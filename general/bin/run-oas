#!/bin/bash

if [ "$#" -ne 2 ]; then
  echo "Usage: run-oas <full-swagger-path.yaml> <port_number>"
  exit 1
fi

SWAGGER_PATH="$1"
PORT="$2"

if [ ! -f "$SWAGGER_PATH" ]; then
  echo "Error: File '$SWAGGER_PATH' not found"
  exit 1
fi

if lsof -nP -iTCP:"$PORT" -sTCP:LISTEN >/tmp/run-oas-lsof-"$PORT" 2>/dev/null; then
  echo "Error: Port $PORT is already in use:" >&2
  cat /tmp/run-oas-lsof-"$PORT" >&2
  rm -f /tmp/run-oas-lsof-"$PORT"
  exit 1
fi
rm -f /tmp/run-oas-lsof-"$PORT"

SWAGGER_DIR=$(dirname "$SWAGGER_PATH")
SWAGGER_FILE=$(basename "$SWAGGER_PATH")

docker run --rm -p "$PORT:8080" -e SWAGGER_JSON=/foo/"$SWAGGER_FILE" -v "$SWAGGER_DIR":/foo swaggerapi/swagger-ui
