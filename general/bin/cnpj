#!/usr/bin/env bash
set -euo pipefail

formatted=false

while getopts ":f" opt; do
  case "$opt" in
    f) formatted=true ;;
    *) echo "Usage: cnpj [-f]" >&2; exit 2 ;;
  esac
done
shift $((OPTIND - 1))

# Generate 12 random digits (8 base + 4 branch)
digits=()
for ((i = 0; i < 12; i++)); do
  digits[i]=$((RANDOM % 10))
done

# First check digit (weights: 5,4,3,2,9,8,7,6,5,4,3,2)
weights1=(5 4 3 2 9 8 7 6 5 4 3 2)
sum=0
for ((i = 0; i < 12; i++)); do
  sum=$((sum + digits[i] * weights1[i]))
done
remainder=$((sum % 11))
d13=$((remainder < 2 ? 0 : 11 - remainder))

# Second check digit (weights: 6,5,4,3,2,9,8,7,6,5,4,3,2)
digits[12]=$d13
weights2=(6 5 4 3 2 9 8 7 6 5 4 3 2)
sum=0
for ((i = 0; i < 13; i++)); do
  sum=$((sum + digits[i] * weights2[i]))
done
remainder=$((sum % 11))
d14=$((remainder < 2 ? 0 : 11 - remainder))

digits[13]=$d14

cnpj_raw=""
for ((i = 0; i < 14; i++)); do
  cnpj_raw+="${digits[i]}"
done

if $formatted; then
  printf '%s.%s.%s/%s-%s\n' \
    "${cnpj_raw:0:2}" \
    "${cnpj_raw:2:3}" \
    "${cnpj_raw:5:3}" \
    "${cnpj_raw:8:4}" \
    "${cnpj_raw:12:2}"
else
  printf '%s\n' "$cnpj_raw"
fi
