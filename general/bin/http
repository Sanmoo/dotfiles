#!/usr/bin/env python3
"""http — minimal REST client that builds and runs curl commands."""
import argparse
import shlex
import sys


def parse_args(argv):
    """Parse CLI arguments.

    This parser allows subcommands for HTTP methods but accepts global options
    either before or after the subcommand. To support options after the
    subcommand we add the same set of "common" arguments to each method
    subparser as well as the top-level parser.
    """
    parser = argparse.ArgumentParser(prog="http", description=__doc__)
    methods = ("get", "post", "put", "patch", "delete")
    subparsers = parser.add_subparsers(dest="method", required=True)

    # helper to add common args to any parser object
    def add_common_args(p):
        p.add_argument("-B", "--base-url", dest="base_url", default=None)
        p.add_argument("path", nargs="?", default=None)
        # The remaining flags are added in later tasks.
        p.add_argument("-t", "--token", dest="token", default=None)
        p.add_argument("-H", "--header", dest="headers", action="append", default=[])
        p.add_argument("-q", "--query", dest="queries", action="append", default=[])
        p.add_argument("-f", "--file", dest="file", default=None)
        p.add_argument("-d", "--data", dest="data", default=None)
        p.add_argument("-v", "--var", dest="vars", action="append", default=[])
        p.add_argument("-i", "--include", dest="include", action="store_true")
        p.add_argument("-n", "--dry-run", dest="dry_run", action="store_true")
        p.add_argument("-k", "--insecure", dest="insecure", action="store_true")
        p.add_argument("-L", "--follow", dest="follow", action="store_true")

    # Create subparsers for each method and add the common args so options
    # placed after the method are accepted.
    for m in methods:
        sp = subparsers.add_parser(m)
        add_common_args(sp)

    return parser.parse_args(argv)


def build_curl_args(args, variables=None):
    # variables is unused in this task; full template pass is wired in Task 6.
    _ = variables
    out = []
    if args.method and args.method != "get":
        out += ["-X", args.method.upper()]
    if args.include:
        out.append("-i")
    if args.insecure:
        out.append("-k")
    if args.follow:
        out.append("-L")
    base = (args.base_url or "").rstrip("/")
    path = (args.path or "").lstrip("/")
    out.append(f"{base}/{path}" if (base or path) else "")
    return out


def format_curl_command(curl_args):
    return " ".join(shlex.quote(a) for a in curl_args)


def main(argv=None):
    args = parse_args(argv if argv is not None else sys.argv[1:])
    curl_args = build_curl_args(args)
    print(format_curl_command(curl_args))
    return 0


if __name__ == "__main__":
    sys.exit(main())
