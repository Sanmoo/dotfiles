#!/usr/bin/env python3
"""http — minimal REST client that builds and runs curl commands."""
import argparse
import os
import shlex
import sys


def _shared_args():
    """Return an argument parser with shared flags used by every subcommand."""
    p = argparse.ArgumentParser(add_help=False)
    p.add_argument("-B", "--base-url", dest="base_url", default=None)
    p.add_argument("path", nargs="?", default=None)
    p.add_argument("-t", "--token", dest="token", default=None)
    p.add_argument("-H", "--header", dest="headers", action="append", default=[])
    p.add_argument("-q", "--query", dest="queries", action="append", default=[])
    p.add_argument("-f", "--file", dest="file", default=None)
    p.add_argument("-d", "--data", dest="data", default=None)
    p.add_argument("-v", "--var", dest="vars", action="append", default=[])
    p.add_argument("-i", "--include", dest="include", action="store_true")
    p.add_argument("-n", "--dry-run", dest="dry_run", action="store_true")
    p.add_argument("-k", "--insecure", dest="insecure", action="store_true")
    p.add_argument("-L", "--follow", dest="follow", action="store_true")
    return p


SHARED_ARGS = _shared_args()


def parse_args(argv):
    parser = argparse.ArgumentParser(prog="http", description=__doc__)
    sub = parser.add_subparsers(dest="method", required=True)
    for m in ("get", "post", "put", "patch", "delete"):
        sub.add_parser(m, parents=[SHARED_ARGS])
    return parser.parse_args(argv)


def resolve_base_url(args, env):
    if args.base_url:
        return args.base_url
    return env.get("HTTP_BASE_URL") or env.get("BASE_URL") or None


def build_curl_args(args, base_url, variables=None):
    # variables is unused in this task; full template pass is wired in Task 7.
    _ = variables
    out = []
    if args.method and args.method != "get":
        out += ["-X", args.method.upper()]
    if args.include:
        out.append("-i")
    if args.insecure:
        out.append("-k")
    if args.follow:
        out.append("-L")
    base = (base_url or "").rstrip("/")
    path = (args.path or "").lstrip("/")
    out.append(f"{base}/{path}" if (base or path) else "")
    return out


def format_curl_command(curl_args):
    return " ".join(shlex.quote(a) for a in curl_args)


def main(argv=None):
    args = parse_args(argv if argv is not None else sys.argv[1:])
    base_url = resolve_base_url(args, os.environ)
    if not base_url:
        print(
            "error: no base URL provided (use -B or set HTTP_BASE_URL)",
            file=sys.stderr,
        )
        return 2
    curl_args = build_curl_args(args, base_url)
    print(format_curl_command(curl_args))
    return 0


if __name__ == "__main__":
    sys.exit(main())
