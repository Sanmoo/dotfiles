#!/usr/bin/env python3
"""http — minimal REST client that builds and runs curl commands."""
import argparse
import os
import re
import shlex
import subprocess
import sys
from pathlib import Path
from urllib.parse import quote_plus

try:
    import yaml
except ImportError:  # pragma: no cover - exercised manually in environments without PyYAML
    yaml = None


_TEMPLATE_RE = re.compile(r"\{\{([^{}]+)\}\}")


def strip_jsonc_comments(text):
    """Remove // and /* */ comments from JSONC text, respecting strings."""
    result = []
    i = 0
    n = len(text)
    in_string = False
    string_char = None
    while i < n:
        c = text[i]
        if in_string:
            result.append(c)
            if c == "\\" and i + 1 < n:
                result.append(text[i + 1])
                i += 2
                continue
            if c == string_char:
                in_string = False
            i += 1
            continue
        if c in ('"', "'"):
            in_string = True
            string_char = c
            result.append(c)
            i += 1
            continue
        if c == "/" and i + 1 < n:
            nxt = text[i + 1]
            if nxt == "/":  # line comment
                while i < n and text[i] != "\n":
                    i += 1
                continue
            if nxt == "*":  # block comment
                i += 2
                while i + 1 < n and not (text[i] == "*" and text[i + 1] == "/"):
                    i += 1
                i += 2
                continue
        result.append(c)
        i += 1
    return "".join(result)


def apply_template(text, variables):
    def repl(m):
        name = m.group(1)
        if name not in variables:
            print(
                f"error: undefined variable in template: {{{{{name}}}}}",
                file=sys.stderr,
            )
            sys.exit(2)
        return variables[name]

    return _TEMPLATE_RE.sub(repl, text)


def parse_vars(var_list):
    out = {}
    for item in var_list or []:
        if "=" not in item:
            print(
                f"error: --var expects KEY=VALUE, got: {item!r}",
                file=sys.stderr,
            )
            sys.exit(2)
        k, v = item.split("=", 1)
        out[k] = v
    return out


def _shared_args():
    """Return an argument parser with shared flags used by every subcommand."""
    p = argparse.ArgumentParser(add_help=False)
    p.add_argument("-B", "--base-url", dest="base_url", default=None)
    p.add_argument("path", nargs="?", default=None)
    p.add_argument("-t", "--token", dest="token", default=None)
    p.add_argument("-H", "--header", dest="headers", action="append", default=[])
    p.add_argument("-q", "--query", dest="queries", action="append", default=[])
    p.add_argument("-f", "--file", dest="file", default=None)
    p.add_argument("-d", "--data", dest="data", default=None)
    p.add_argument("-v", "--var", dest="vars", action="append", default=[])
    p.add_argument("-i", "--include", dest="include", action="store_true")
    p.add_argument("-n", "--dry-run", dest="dry_run", action="store_true")
    p.add_argument("-k", "--insecure", dest="insecure", action="store_true")
    p.add_argument("-L", "--follow", dest="follow", action="store_true")
    return p


SHARED_ARGS = _shared_args()


def make_oc_parser():
    p = argparse.ArgumentParser(prog="http oc", description="Run OpenCollection request")
    p.add_argument("request_name", nargs="?", default=None)
    p.add_argument("-c", "--collection", dest="collection", default=None)
    p.add_argument("-e", "--environment", dest="environment", default=None)
    p.add_argument("-v", "--var", dest="vars", action="append", default=[])
    p.add_argument("--no-interactive", dest="no_interactive", action="store_true")
    p.add_argument("-n", "--dry-run", dest="dry_run", action="store_true")
    p.add_argument("-i", "--include", dest="include", action="store_true")
    p.add_argument("-k", "--insecure", dest="insecure", action="store_true")
    p.add_argument("-L", "--follow", dest="follow", action="store_true")
    p.add_argument("-H", "--header", dest="headers", action="append", default=[])
    p.add_argument("-q", "--query", dest="queries", action="append", default=[])
    return p


def parse_oc_vars(raw_values):
    out = {}
    for raw in raw_values or []:
        for item in raw.split(","):
            if not item:
                continue
            if "=" not in item:
                print(f"error: --var expects KEY=VALUE, got: {item!r}", file=sys.stderr)
                sys.exit(2)
            key, value = item.split("=", 1)
            if not key:
                print("error: --var key cannot be empty", file=sys.stderr)
                sys.exit(2)
            out[key] = value
    return out


def parse_args(argv):
    if argv and argv[0] == "oc":
        args = make_oc_parser().parse_args(argv[1:])
        args.method = "oc"
        return args
    parser = argparse.ArgumentParser(prog="http", description=__doc__)
    sub = parser.add_subparsers(dest="method", required=True)
    for m in ("get", "post", "put", "patch", "delete"):
        sub.add_parser(m, parents=[SHARED_ARGS])
    return parser.parse_args(argv)


def resolve_base_url(args, env):
    if args.base_url:
        return args.base_url
    return env.get("HTTP_BASE_URL") or env.get("BASE_URL") or None


def has_header(headers, header_name):
    needle = header_name.lower()
    return any(
        h.split(":", 1)[0].strip().lower() == needle
        for h in headers or []
    )


def resolve_auto_content_type(args):
    if has_header(args.headers, "Content-Type"):
        return None
    if args.file:
        ext = Path(args.file).suffix.lower()
        if ext in (".json", ".jsonc"):
            return "application/json"
        if ext == ".xml":
            return "application/xml"
        return "application/octet-stream"
    if args.method == "get":
        return "application/json"
    return None


def build_curl_args(args, base_url, variables=None):
    _ = variables
    out = []
    if args.method and args.method != "get":
        out += ["-X", args.method.upper()]
    if args.include:
        out.append("-i")
    if args.insecure:
        out.append("-k")
    if args.follow:
        out.append("-L")
    for h in args.headers or []:
        out += ["-H", h]
    if args.token:
        out += ["-H", f"Authorization: Bearer {args.token}"]

    auto_content_type = resolve_auto_content_type(args)
    if auto_content_type is not None:
        out += ["-H", f"Content-Type: {auto_content_type}"]

    # Body handling
    body_arg = None
    if args.file and args.data is not None:
        pass  # main() guards this
    elif args.file:
        body_arg = f"@{args.file}"
        if getattr(args, "file_body", None) is not None:
            body_arg = args.file_body
    elif args.data is not None:
        body_arg = args.data

    base = (base_url or "").rstrip("/")
    path = (args.path or "").lstrip("/")
    url = f"{base}/{path}" if (base or path) else ""
    if args.queries:
        parts = []
        for q in args.queries:
            if "=" not in q:
                k, v = q, ""
            else:
                k, v = q.split("=", 1)
            parts.append(f"{k}={quote_plus(v)}")
        url = f"{url}?{'&'.join(parts)}"
    out.append(url)

    if body_arg is not None:
        out += ["--data", body_arg]

    return out


def format_curl_command(curl_args):
    return " ".join(shlex.quote(a) for a in curl_args)


OC_MANIFEST_NAMES = (
    "opencollection.yaml",
    "opencollection.yml",
    "collection.yaml",
    "collection.yml",
)


def die(message):
    print(f"error: {message}", file=sys.stderr)
    sys.exit(2)


def load_yaml_file(path):
    if yaml is None:
        die("PyYAML is required for http oc")
    try:
        with path.open(encoding="utf-8") as f:
            data = yaml.safe_load(f)
    except FileNotFoundError:
        die(f"YAML file not found: {path}")
    except Exception as e:
        die(f"invalid YAML in {path}: {e}")
    return data or {}


def expand_config_path(value):
    return Path(os.path.expandvars(os.path.expanduser(str(value))))


def load_httprc(home):
    path = home / ".config" / ".httprc"
    if not path.is_file():
        die("~/.config/.httprc not found; expected YAML with a collections: list")
    data = load_yaml_file(path)
    if not isinstance(data, dict):
        die("~/.config/.httprc must be a YAML mapping containing collections: as a list")
    roots = data.get("collections")
    if not isinstance(roots, list):
        die("~/.config/.httprc must contain collections: as a list")
    return {"path": path, "roots": [expand_config_path(p) for p in roots]}


def find_collection_manifest(directory):
    for name in OC_MANIFEST_NAMES:
        candidate = directory / name
        if candidate.is_file():
            return candidate
    return None


def discover_collections(roots):
    found = []
    for root in roots:
        if not root.is_dir():
            continue
        for current, dirs, _files in os.walk(root):
            current_path = Path(current)
            manifest = find_collection_manifest(current_path)
            if not manifest:
                continue
            data = load_yaml_file(manifest)
            if not isinstance(data, dict):
                die(f"collection manifest must be a YAML mapping: {manifest}")
            info = data.get("info") if isinstance(data.get("info"), dict) else {}
            name = info.get("name") or current_path.name
            found.append({
                "name": str(name),
                "path": current_path,
                "manifest_path": manifest,
                "manifest": data,
            })
            dirs[:] = []
    return found


def choose_with_fzf_or_prompt(items, label, format_item):
    if not items:
        die(f"no {label} choices available")
    # Full fzf behavior is added in a later task. For now, a single item can be selected.
    if len(items) == 1:
        return items[0]
    die(f"interactive {label} selection is not implemented yet; pass an explicit value")


def select_collection(collections, name, interactive):
    if not collections:
        die("no collections discovered from ~/.config/.httprc roots")
    if name:
        matches = [c for c in collections if c["name"] == name or c["path"].name == name]
        if len(matches) == 1:
            return matches[0]
        if len(matches) > 1:
            if interactive:
                return choose_with_fzf_or_prompt(matches, "collection", lambda c: f"{c['name']}\t{c['path']}")
            die("collection name is ambiguous: " + ", ".join(str(c["path"]) for c in matches))
        die("collection not found: " + name + "; available: " + ", ".join(c["name"] for c in collections))
    if interactive:
        return choose_with_fzf_or_prompt(collections, "collection", lambda c: f"{c['name']}\t{c['path']}")
    die("collection is required; pass -c/--collection")


def main_oc(args):
    parse_oc_vars(args.vars)
    interactive = (not args.no_interactive) and sys.stdin.isatty() and sys.stdout.isatty()
    config = load_httprc(Path.home())
    collections = discover_collections(config["roots"])
    collection = select_collection(collections, args.collection, interactive)
    print(f"error: request discovery is not implemented for collection {collection['name']}", file=sys.stderr)
    return 2


def main(argv=None):
    args = parse_args(argv if argv is not None else sys.argv[1:])
    if args.method == "oc":
        return main_oc(args)

    if args.token is not None and not args.token.strip():
        print("error: --token is empty", file=sys.stderr)
        return 2

    if args.file and args.data is not None:
        print("error: --file and --data are mutually exclusive", file=sys.stderr)
        return 2

    if args.file and not Path(args.file).is_file():
        print(f"error: file not found: {args.file}", file=sys.stderr)
        return 2

    variables = parse_vars(args.vars)
    if args.data is not None:
        args.data = apply_template(args.data, variables)
    if args.token is not None:
        args.token = apply_template(args.token, variables)
    if args.headers:
        args.headers = [
            apply_template(h, variables) for h in args.headers
        ]
    if args.path is not None:
        args.path = apply_template(args.path, variables)
    if args.queries:
        args.queries = [apply_template(q, variables) for q in args.queries]
    if args.file:
        content = Path(args.file).read_text()
        if Path(args.file).suffix.lower() == ".jsonc":
            content = strip_jsonc_comments(content)
        if variables or Path(args.file).suffix.lower() == ".jsonc":
            args.file_body = apply_template(content, variables)
    if args.base_url:
        args.base_url = apply_template(args.base_url, variables)

    base_url = resolve_base_url(args, os.environ)
    if not base_url:
        print(
            "error: no base URL provided (use -B or set HTTP_BASE_URL)",
            file=sys.stderr,
        )
        return 2
    curl_args = build_curl_args(args, base_url)
    if args.dry_run:
        print(format_curl_command(curl_args))
        return 0
    result = subprocess.run(["curl", *curl_args])
    return result.returncode


if __name__ == "__main__":
    sys.exit(main())
